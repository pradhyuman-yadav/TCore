DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=tradecore

# Claude / Anthropic — choose ONE method:
#
# Option A (recommended for servers): Anthropic API key
#   Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...
#
# Option B (local dev only): Claude Code OAuth tokens
#   Run scripts/setup_claude_auth.ps1 locally, then copy values here.
#   OAuth refresh does NOT work on remote servers — use Option A there.
# CLAUDE_ACCESS_TOKEN=sk-ant-oat01-...
# CLAUDE_REFRESH_TOKEN=sk-ant-ort01-...
# CLAUDE_TOKEN_EXPIRES_AT=0

# Exchange (CCXT)
